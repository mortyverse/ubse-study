# ── Supabase (dev: study-site-dev / prod: study-site-prod — Vercel에는 prod 값 입력) ──
# Project URL — 대시보드 Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# publishable key (legacy anon key도 사용 가능) — 브라우저 노출 OK, RLS로 보호됨
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key
# service_role(secret) key — 서버 전용. 절대 NEXT_PUBLIC_ 접두사 금지, 절대 커밋 금지
SUPABASE_SECRET_KEY=your-service-role-or-secret-key

# ── GitHub OAuth ──
# 실제 설정 위치는 Supabase 대시보드 > Authentication > Providers > GitHub.
# 앱 코드에서 직접 읽지 않지만, 키 관리 목록으로 여기 항목을 유지한다.
GITHUB_OAUTH_CLIENT_ID=your-github-oauth-client-id
GITHUB_OAUTH_CLIENT_SECRET=your-github-oauth-client-secret

# ── Gemini (AI 1차 채점, 서버 전용) ──
GEMINI_API_KEY=your-gemini-api-key
